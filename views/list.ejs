<div class="mb-3">
  <h4 class="fw-bold"><%= title %></h4>
</div>

<!-- 搜索栏 -->
<div class="card mb-3">
  <div class="card-body">
    <form method="GET" action="<%= basePath %>" class="row g-2 align-items-end">
      <% searchFields.forEach(function(f) { %>
      <div class="col-md-3">
        <label class="form-label small text-muted"><%= f.label %></label>
        <input type="text" name="<%= f.name %>" class="form-control form-control-sm" value="<%= searchValues[f.name] || '' %>" placeholder="<%= f.label %>">
      </div>
      <% }) %>
      <div class="col-md-3">
        <button type="submit" class="btn btn-primary btn-sm me-1"><i class="bi bi-search"></i> 搜索</button>
        <a href="<%= basePath %>" class="btn btn-outline-secondary btn-sm">重置</a>
      </div>
    </form>
  </div>
</div>

<!-- 新建按钮 -->
<div class="mb-2">
  <a href="<%= basePath %>/new" class="btn btn-primary btn-sm"><i class="bi bi-plus-circle"></i> 新建</a>
</div>

<!-- 数据表格 -->
<div class="card">
  <div class="card-body p-0">
    <table class="table table-hover table-sm mb-0">
      <thead class="table-light">
        <tr>
          <th>#</th>
          <% listFields.forEach(function(f) { %>
          <th><%= f.label %></th>
          <% }) %>
          <th style="width:140px">操作</th>
        </tr>
      </thead>
      <tbody>
        <% if (rows.length === 0) { %>
        <tr><td colspan="<%= listFields.length + 2 %>" class="text-center text-muted py-4">暂无数据</td></tr>
        <% } else { %>
        <% rows.forEach(function(row) { %>
        <tr>
          <td><%= row.id || row.dataId %></td>
          <% listFields.forEach(function(f) { %>
          <td>
            <% if (f.type === 'badge') { %>
              <span class="badge bg-secondary"><%= row[f.name] || '-' %></span>
            <% } else if (f.type === 'score') { %>
              <span class="badge bg-primary"><%= row[f.name] || '-' %></span>
            <% } else if (f.type === 'status') { %>
              <span class="badge bg-<%= row[f.name] === '活跃' || row[f.name] === 'active' ? 'success' : 'warning' %>"><%= row[f.name] || '-' %></span>
            <% } else if (f.type === 'date') { %>
              <%= (row[f.name] || '-').substring(0, 16) %>
            <% } else { %>
              <span title="<%= row[f.name] || '' %>"><%= (row[f.name] || '-').substring(0, 30) %><%= (row[f.name] || '').length > 30 ? '...' : '' %></span>
            <% } %>
          </td>
          <% }) %>
          <td>
            <a href="<%= basePath %>/<%= row.id || row.dataId %>/edit" class="btn btn-outline-primary btn-sm"><i class="bi bi-pencil"></i></a>
            <form method="POST" action="<%= basePath %>/<%= row.id || row.dataId %>/delete" class="d-inline" data-confirm="确定要删除这条记录吗？删除后不可恢复！">
              <button type="submit" class="btn btn-outline-danger btn-sm"><i class="bi bi-trash"></i></button>
            </form>
          </td>
        </tr>
        <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>
</div>
