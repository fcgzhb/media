<div class="mb-4">
  <h4 class="fw-bold">控制台</h4>
  <p class="text-muted">欢迎回来，<%= username %></p>
</div>

<!-- 统计卡片 -->
<div class="row g-3 mb-4">
  <div class="col-md-3">
    <div class="card text-white bg-primary">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <div class="text-white-50 small">内容总数</div>
            <h3 class="mb-0"><%= stats.contents %></h3>
          </div>
          <i class="bi bi-file-earmark-text fs-2"></i>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card text-white bg-success">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <div class="text-white-50 small">发布计划</div>
            <h3 class="mb-0"><%= stats.publishPlans %></h3>
          </div>
          <i class="bi bi-calendar-event fs-2"></i>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card text-white bg-warning">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <div class="text-white-50 small">社交账户</div>
            <h3 class="mb-0"><%= stats.accounts %></h3>
          </div>
          <i class="bi bi-person-badge fs-2"></i>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card text-white bg-info">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <div class="text-white-50 small">活动策略</div>
            <h3 class="mb-0"><%= stats.activities %></h3>
          </div>
          <i class="bi bi-bullseye fs-2"></i>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="row g-3">
  <!-- 快捷操作 -->
  <div class="col-md-6">
    <div class="card">
      <div class="card-header"><i class="bi bi-lightning"></i> 快捷操作</div>
      <div class="card-body">
        <div class="d-flex flex-wrap gap-2">
          <a href="/contents/new" class="btn btn-outline-primary btn-sm"><i class="bi bi-plus-circle"></i> 新建内容</a>
          <a href="/publish-plans/new" class="btn btn-outline-success btn-sm"><i class="bi bi-plus-circle"></i> 新建计划</a>
          <a href="/templates/new" class="btn btn-outline-info btn-sm"><i class="bi bi-plus-circle"></i> 新建模板</a>
          <a href="/activities/new" class="btn btn-outline-warning btn-sm"><i class="bi bi-plus-circle"></i> 新建活动</a>
          <a href="/accounts/new" class="btn btn-outline-secondary btn-sm"><i class="bi bi-plus-circle"></i> 添加账户</a>
          <a href="/recommendations/new" class="btn btn-outline-dark btn-sm"><i class="bi bi-plus-circle"></i> 新建推荐</a>
        </div>
      </div>
    </div>
  </div>

  <!-- 最新发布计划 -->
  <div class="col-md-6">
    <div class="card">
      <div class="card-header"><i class="bi bi-clock-history"></i> 最新发布计划</div>
      <div class="card-body p-0">
        <table class="table table-sm mb-0">
          <thead><tr><th>标题</th><th>平台</th><th>计划时间</th><th>评分</th></tr></thead>
          <tbody>
            <% recentPlans.forEach(function(p) { %>
            <tr>
              <td><%= p.contentTitle %></td>
              <td><span class="badge bg-secondary"><%= p.platform %></span></td>
              <td><%= p.scheduledTime %></td>
              <td><span class="badge bg-primary"><%= p.engagementScore %></span></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- 趋势排行 -->
  <div class="col-md-6">
    <div class="card">
      <div class="card-header"><i class="bi bi-graph-up-arrow"></i> 热门趋势</div>
      <div class="card-body p-0">
        <table class="table table-sm mb-0">
          <thead><tr><th>趋势名称</th><th>类型</th><th>平台</th><th>影响力</th></tr></thead>
          <tbody>
            <% topTrends.forEach(function(t) { %>
            <tr>
              <td><%= t.trendName %></td>
              <td><span class="badge bg-info"><%= t.trendType %></span></td>
              <td><%= t.platforms %></td>
              <td><span class="badge bg-danger"><%= t.trendImpactScore %></span></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- 账户概况 -->
  <div class="col-md-6">
    <div class="card">
      <div class="card-header"><i class="bi bi-people"></i> 社交账户概况</div>
      <div class="card-body p-0">
        <table class="table table-sm mb-0">
          <thead><tr><th>账户名称</th><th>平台</th><th>状态</th><th>参与度</th></tr></thead>
          <tbody>
            <% accountList.forEach(function(a) { %>
            <tr>
              <td><%= a.accountName %></td>
              <td><span class="badge bg-secondary"><%= a.platform %></span></td>
              <td><span class="badge bg-<%= a.accountStatus === '活跃' ? 'success' : 'warning' %>"><%= a.accountStatus %></span></td>
              <td><span class="badge bg-primary"><%= a.accountEngagementScore %></span></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
