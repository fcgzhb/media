<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>社交媒体内容智能排期软件</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="d-flex">
    <!-- 左侧边栏 -->
    <nav id="sidebar" class="bg-dark text-white" style="width: 220px; min-height: 100vh; position: fixed; top: 0; left: 0; z-index: 1000;">
      <div class="sidebar-brand text-center py-3 border-bottom border-secondary">
        <i class="bi bi-calendar2-check fs-4"></i>
        <div class="fs-6 mt-1">内容智能排期</div>
      </div>
      <ul class="nav flex-column py-2">
        <li class="nav-item">
          <a class="nav-link text-white" href="/"><i class="bi bi-speedometer2"></i> 控制台</a>
        </li>
        <li class="nav-item mt-2"><span class="nav-link text-secondary small px-3">基础管理</span></li>
        <li class="nav-item">
          <a class="nav-link text-white" href="/users"><i class="bi bi-people"></i> 用户管理</a>
        </li>
        <li class="nav-item">
          <a class="nav-link text-white" href="/contents"><i class="bi bi-file-earmark-text"></i> 内容库管理</a>
        </li>
        <li class="nav-item">
          <a class="nav-link text-white" href="/templates"><i class="bi bi-file-earmark-richtext"></i> 内容模板管理</a>
        </li>
        <li class="nav-item mt-2"><span class="nav-link text-secondary small px-3">发布管理</span></li>
        <li class="nav-item">
          <a class="nav-link text-white" href="/publish-plans"><i class="bi bi-calendar-event"></i> 发布计划管理</a>
        </li>
        <li class="nav-item">
          <a class="nav-link text-white" href="/publish-logs"><i class="bi bi-journal-text"></i> 发布日志管理</a>
        </li>
        <li class="nav-item mt-2"><span class="nav-link text-secondary small px-3">账户与智能</span></li>
        <li class="nav-item">
          <a class="nav-link text-white" href="/accounts"><i class="bi bi-person-badge"></i> 社交账户管理</a>
        </li>
        <li class="nav-item">
          <a class="nav-link text-white" href="/recommendations"><i class="bi bi-lightbulb"></i> 智能推荐设置</a>
        </li>
        <li class="nav-item">
          <a class="nav-link text-white" href="/activities"><i class="bi bi-bullseye"></i> 活动策略管理</a>
        </li>
        <li class="nav-item mt-2"><span class="nav-link text-secondary small px-3">数据分析</span></li>
        <li class="nav-item">
          <a class="nav-link text-white" href="/trends"><i class="bi bi-graph-up-arrow"></i> 趋势监测管理</a>
        </li>
      </ul>
      <div class="border-top border-secondary mt-auto p-3">
        <a class="nav-link text-warning" href="/logout"><i class="bi bi-box-arrow-left"></i> 退出登录</a>
      </div>
    </nav>

    <!-- 主内容区 -->
    <div class="flex-grow-1" style="min-height: 100vh; background: #f5f6fa; margin-left: 220px;">
      <div class="p-4">
        <%- body %>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      document.querySelectorAll('[data-confirm]').forEach(function (form) {
        form.addEventListener('submit', function (e) {
          if (!confirm(form.getAttribute('data-confirm'))) {
            e.preventDefault();
          }
        });
      });
    });
  </script>
</body>
</html>
